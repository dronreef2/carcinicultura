# Banco
POSTGRES_DB=camarao_iot
POSTGRES_USER=camarao
POSTGRES_PASSWORD=troque_por_senha_forte

# MQTT
MQTT_USER=camarao
MQTT_PASSWORD=troque_por_senha_forte

# Backend
# Em producao, coloque dominio(s) exatos do dashboard
CORS_ORIGINS=*
ACTUATOR_MQTT_TOPIC_TEMPLATE=farm/{farm_id}/pond/{pond_id}/actuator/{actuator_type}/set
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_MIN_SEVERITY=warning

# Dashboard
# auto tenta API e cai para simulacao se backend estiver fora
DASHBOARD_DATA_SOURCE=auto
BACKEND_API_URL=http://backend:8000
API_TIMEOUT_S=8

# Cloudflare Tunnel (HTTPS gratis)
# Crie no painel Zero Trust e cole o token do tunnel
CLOUDFLARE_TUNNEL_TOKEN=
