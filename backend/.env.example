# ╔══════════════════════════════════════════════════════════════════════════════╗
# ║  Variáveis de Ambiente — IoT Camarão                                       ║
# ║  Copie este arquivo para ".env" e preencha com os valores reais.            ║
# ║  NUNCA commite o arquivo .env no repositório.                               ║
# ╚══════════════════════════════════════════════════════════════════════════════╝

# ─── Banco de Dados (TimescaleDB / PostgreSQL) ─────────────────────────────────
POSTGRES_DB=camarao_iot
POSTGRES_USER=camarao
POSTGRES_PASSWORD=TROQUE_POR_UMA_SENHA_FORTE

# ─── Broker MQTT (Mosquitto) ───────────────────────────────────────────────────
MQTT_USER=camarao
MQTT_PASSWORD=TROQUE_POR_UMA_SENHA_FORTE

# ─── Backend FastAPI ───────────────────────────────────────────────────────────
# Origens CORS permitidas (separadas por vírgula, ou "*" para todas — não recomendado em produção)
# Exemplo produção: CORS_ORIGINS=https://meu-dashboard.exemplo.com,https://app.exemplo.com
CORS_ORIGINS=*
